{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/internal.ts!",
    ".storybook/{main,manager,preview}.ts",
    "stories/**/story.tsx",
    "stories/**/*.mdx"
  ],
  "ignore": ["**/*.css"],
  "ignoreDependencies": [
    "react-scan",
    "@babel/preset-env",
    "@babel/preset-react",
    "@babel/preset-typescript",
    "babel-plugin-react-compiler",
    "react18-dom",
    "@storybook/react"
  ],
  "ignoreExportsUsedInFile": false
}
